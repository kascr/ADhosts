<?xml version="1.0" encoding="utf-8"?>
<!--
    自定义底部导航栏
    - 三个导航项等宽排列
    - 选中项：图标+文字垂直居中，外包圆角胶囊高亮背景
    - 未选中项：只显示图标，图标颜色变暗
    - 图标与文字间距完全由 layout_marginTop 控制，无 Material 内部干扰
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:background="@color/md_theme_surface"
    android:elevation="8dp">

    <!-- 导航项 1：Hosts 管理 -->
    <LinearLayout
        android:id="@+id/nav_item_1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- 胶囊高亮容器 -->
        <LinearLayout
            android:id="@+id/nav_pill_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/nav_icon_1"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_shield"
                android:tint="#8B949E" />

            <TextView
                android:id="@+id/nav_label_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Hosts 管理"
                android:textSize="11sp"
                android:textColor="#8B949E"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- 导航项 2：功能工具 -->
    <LinearLayout
        android:id="@+id/nav_item_2"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/nav_pill_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/nav_icon_2"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_wrench"
                android:tint="#8B949E" />

            <TextView
                android:id="@+id/nav_label_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="功能工具"
                android:textSize="11sp"
                android:textColor="#8B949E"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- 导航项 3：设置 -->
    <LinearLayout
        android:id="@+id/nav_item_3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/nav_pill_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/nav_icon_3"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:tint="#8B949E" />

            <TextView
                android:id="@+id/nav_label_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="设置"
                android:textSize="11sp"
                android:textColor="#8B949E"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
