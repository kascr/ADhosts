<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ===== 顶部 Header（参考项目 header 样式：返回按钮圆形 + 标题） ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="0dp"
                android:paddingBottom="16dp">

                <!-- 圆形返回按钮（参考项目 backBtn: 36x36 圆形, surface 背景, border 边框） -->
                <FrameLayout
                    android:id="@+id/backButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/circle_back_btn_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_back"
                        app:tint="?attr/colorOnSurface" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/tool_decibel"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ===== 圆形仪表盘区域（参考项目 gaugeContainer） ===== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="32dp">

                <!-- 外圆（参考项目 gaugeOuter: 220x220, 3px border, surface bg） -->
                <View
                    android:id="@+id/gaugeOuter"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center"
                    android:background="@drawable/gauge_outer_bg" />

                <!-- 内圆 + 数值（参考项目 gaugeInner: 180x180） -->
                <LinearLayout
                    android:id="@+id/gaugeInner"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/gauge_inner_bg"
                    android:gravity="center"
                    android:orientation="vertical">

                    <!-- 分贝数值（参考项目 decibelValue: 56sp, 800 weight, letterSpacing -2） -->
                    <TextView
                        android:id="@+id/dbValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.05" />

                    <!-- 单位（参考项目 decibelUnit: 18sp, muted color, marginTop -4） -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="dB"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="-4dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- ===== 状态徽章（参考项目 categoryBadge） ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:layout_marginTop="-16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/categoryBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_bg"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:text="@string/decibel_not_measured"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ===== 当前分贝 / 峰值 双卡片（参考项目 statsRow） ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="24dp">

                <!-- 当前分贝卡片（参考项目 statCard: surface bg, 14dp radius, 1px border） -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- statLabel: 12sp, muted -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/decibel_current"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <!-- statValue: 24sp, 700 weight -->
                        <TextView
                            android:id="@+id/currentDbText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <!-- statUnit: 12sp, muted -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="dB"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 峰值卡片 -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/decibel_peak"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <!-- 峰值用 error 色（参考项目 colors.error） -->
                        <TextView
                            android:id="@+id/maxDbText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="#F87171"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="dB"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ===== 噪音等级参考卡片（参考项目 levelBar） ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="14dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- levelBarTitle: 14sp, 600 weight -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/decibel_level_ref"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- 五段彩色进度条（参考项目 levelRow: 5段, 8dp高, 4dp圆角, gap=4） -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <View
                            android:id="@+id/levelSeg0"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="2dp"
                            android:background="@drawable/level_seg_bg"
                            android:backgroundTint="#26A69A"
                            android:alpha="0.3" />

                        <View
                            android:id="@+id/levelSeg1"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:background="@drawable/level_seg_bg"
                            android:backgroundTint="#43A047"
                            android:alpha="0.3" />

                        <View
                            android:id="@+id/levelSeg2"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:background="@drawable/level_seg_bg"
                            android:backgroundTint="#FB8C00"
                            android:alpha="0.3" />

                        <View
                            android:id="@+id/levelSeg3"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:background="@drawable/level_seg_bg"
                            android:backgroundTint="#E53935"
                            android:alpha="0.3" />

                        <View
                            android:id="@+id/levelSeg4"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginStart="2dp"
                            android:background="@drawable/level_seg_bg"
                            android:backgroundTint="#B71C1C"
                            android:alpha="0.3" />
                    </LinearLayout>

                    <!-- 等级标签（参考项目 levelLabels: space-between） -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/decibel_quiet"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/decibel_normal"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/decibel_noisy"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="@string/decibel_danger"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== 开始/停止按钮（参考项目 controlBtn: 16dp radius, 18dp paddingVertical, row layout） ===== -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/controlButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:paddingVertical="16dp"
                android:text="@string/decibel_start"
                android:textSize="17sp"
                android:textStyle="bold"
                android:backgroundTint="#26A69A"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_waveform"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="@android:color/white" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
